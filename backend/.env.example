# Port for backend service
PORT=5000

# IBM Watsonx Orchestrate Channel Credentials
IBM_ORCHESTRATE_INTEGRATION_ID=
IBM_ORCHESTRATE_CRN=
IBM_ORCHESTRATE_AGENT_ID=
IBM_ORCHESTRATE_HOST_URL=
IBM_ORCHESTRATE_AGENT_ENV_ID=live

# (Optional) RSA Private Key in PEM format to sign JWT tokens for Secure Web Chat mode
# Replace literal newlines with \n when setting this in a single line env variable
IBM_ORCHESTRATE_PRIVATE_KEY=

